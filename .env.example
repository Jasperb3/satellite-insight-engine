# Google Earth Engine project id (run `earthengine authenticate` first)
GEE_PROJECT=your-gee-project-id

# Nominatim (OpenStreetMap) user agent — use a unique string for your app
NOMINATIM_AGENT=satellite-insight-engine

# Ollama hosted web search (optional). If unset, enrichment falls back to free sources.
OLLAMA_API_KEY=

# Models (already pulled locally)
VISION_MODEL=minicpm-v4.5:q8_0
AGENT_MODEL=lfm2.5:latest

# Behaviour
RETENTION_DAYS=30
DEFAULT_BUFFER=2500
